# Copy this file to .env and fill in your real values. Never commit the real .env file.

DB_HOST=localhost
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=changeme
DB_NAME=appdb

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRY_HOURS=12

# Comma separated list of origins allowed to call this API (your frontend URL)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
